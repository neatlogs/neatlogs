# =============================================================================
# Neatlogs
# =============================================================================
NEATLOGS_API_KEY=your_neatlogs_api_key_here
# NEATLOGS_ENDPOINT=https://staging-cloud.neatlogs.com/api/data/v4/batch
# NEATLOGS_DEBUG=false

# =============================================================================
# Azure OpenAI  (used by all CrewAI agents)
# =============================================================================
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# =============================================================================
# Google Gemini  (used by the grounded search tool)
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
