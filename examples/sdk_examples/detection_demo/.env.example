# NeatLogs (required)
NEATLOGS_API_KEY=your_neatlogs_api_key_here
NEATLOGS_ENDPOINT=https://staging-cloud.neatlogs.com

# Azure OpenAI (required when USE_AZURE=true)
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview
USE_AZURE=true

# OpenAI (optional — needed for adversarial classifier scenarios in sales workflow)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Google Gemini (required for workflow 5)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash
