# NeatLogs (required)
NEATLOGS_API_KEY=your_neatlogs_api_key_here
NEATLOGS_ENDPOINT=https://staging-cloud.neatlogs.com

# Azure OpenAI (required)
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# SendGrid — RUN=A uses SENDGRID_API_KEY_BROKEN (intentional 401).
# For RUN=B / RUN=B_FIXED without a real key, set SENDGRID_FAKE_SUCCESS=1.
SENDGRID_API_KEY_VALID=SG.replace-with-real-key-or-any-string
SENDGRID_API_KEY_BROKEN=SG.deliberately-revoked-for-demo
SENDGRID_FROM=support@example.com
SENDGRID_TO=demo+inbound@example.com

# Optional: stub email delivery with httpbin (keeps requests auto-instrumentation)
# SENDGRID_FAKE_SUCCESS=1

# Public KB URLs cited in retriever output
KB_SITE_BASE_URL=https://neatlogs.github.io/support-copilot-demo-kb
