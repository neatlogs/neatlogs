# =============================================================================
# Detection Demo - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Then edit .env with your actual values.
# =============================================================================

# -----------------------------------------------------------------------------
# Neatlogs Configuration (REQUIRED)
# -----------------------------------------------------------------------------
NEATLOGS_API_KEY=your_neatlogs_api_key_here
NEATLOGS_ENDPOINT=staging_endpoint_backend
PROJECT_ID=your_project_id_here

# -----------------------------------------------------------------------------
# OpenAI (REQUIRED - used for adversarial scenarios 3-6)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# -----------------------------------------------------------------------------
# Azure OpenAI (REQUIRED - used for normal scenarios 1-2, 7-10)
# -----------------------------------------------------------------------------
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.1
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Use Azure as default LLM (workflow switches to OpenAI for adversarial inputs)
USE_AZURE=true

# -----------------------------------------------------------------------------
# Optional: Debug Settings
# -----------------------------------------------------------------------------
DEBUG=true
