include README.MD
include LICENSE
include pyproject.toml

recursive-include neatlogs *.py
recursive-include neatlogs *.md
recursive-include neatlogs *.txt
recursive-include neatlogs *.yml
recursive-include neatlogs *.yaml
recursive-include neatlogs/config *.json
prune neatlogs/examples
recursive-exclude neatlogs/examples *

global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.so
global-exclude .DS_Store
global-exclude .git
global-exclude .gitignore
global-exclude .env
global-exclude *.log
global-exclude venv/
global-exclude .venv/
global-exclude .python-version
